# ─────────────────────────────────────────────────────────────
# Supabase — variables de entorno
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore: NUNCA se sube a GitHub.
# ─────────────────────────────────────────────────────────────

# PÚBLICAS (pueden viajar al navegador, por eso llevan NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# SECRETA — SOLO SERVIDOR.
# Esta llave salta todas las reglas de seguridad (RLS).
# NUNCA le pongas el prefijo NEXT_PUBLIC_ y NUNCA la uses en código de cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
